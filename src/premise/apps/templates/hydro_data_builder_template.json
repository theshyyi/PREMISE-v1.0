{
  "app_type": "hydro_data_builder",
  "name": "build_for_hydrological_model",
  "output_dir": "I:/PREMISE_runs/hydro_data_builder",
  "time_range": {
    "start": "2020-01-01",
    "end": "2020-12-31"
  },
  "region": {
    "path": "I:/region/basin.shp",
    "field": "BASIN",
    "values": ["Hanjiang"]
  },
  "bbox": [108.0, 30.0, 115.0, 35.0],
  "target_resolution": 0.1,
  "resample_method": "linear",
  "merge_prepared": true,
  "merged_filename": "hydro_model_input.nc",
  "requests": [
    {
      "source_key": "chirps_daily_tif",
      "variables": ["precipitation"],
      "rename_map": {"pr": "pr"},
      "pass_bbox_to_downloader": false
    },
    {
      "source_key": "era5land_hourly",
      "variables": ["2m_temperature"],
      "rename_map": {"t2m": "tas", "2m_temperature": "tas"},
      "pass_bbox_to_downloader": true,
      "downloader_kwargs": {}
    }
  ]
}
